# Build output
bin/
obj/
[Dd]ebug/
[Rr]elease/

# Test run output (dotnet test --logger trx writes TestResults/*.trx)
TestResults/
*.trx
x64/
x86/
[Bb]uild/
[Pp]ublish/
*.user
*.suo
*.userosscache
*.sln.docstates

# IDE
.vs/
.vscode/
.idea/
*.swp

# Claude Code — per-machine local settings (shared .claude/settings.json may be tracked)
.claude/settings.local.json

# Local scratch — screenshots and other debug artefacts shared with Claude
# during sessions. The `[Dd]ebug/` rule above only catches build dirs; the
# leading-dot variant is for Drew's IDE-side workspace.
.debug/

# security-audit skill output — per-run audit reports. Living-doc summary
# of audit posture is in SECURITY-AUDIT.md; the per-run snapshots stay
# local because they may surface ongoing soft-spots we don't want
# advertised in a public repo.
audits/

# Playwright failure dumps (PNG + HTML), written to bin on E2E test
# failure. Local-only by design — no value committing them.
**/e2e-artifacts/

# Azurite local-dev blob persistence. Holds covers uploaded by the
# IBookCoverStorage service when running against the Azurite emulator.
# Survives container restarts (volume bind-mount) but is local-only.
azurite-data/

# Azurite TLS certs generated per-machine via mkcert. Each dev runs
# `mkcert localhost 127.0.0.1 ::1` and drops the resulting PEM files
# in here; they're trusted only on the machine that ran `mkcert -install`.
# See docs/LOCAL-DEV.md.
azurite-certs/

# .NET
project.lock.json
project.fragment.lock.json
artifacts/
*.pdb

# Snapshot dumps from infra/dump-prod-to-json.ps1 — production data
# intended for upload into the local "BookTracker Analysis" Claude
# Project. Stays local; never committed.
snapshots/

# App config with secrets — committed only as *.Example.json templates
appsettings.json
appsettings.*.json
!appsettings.Example.json
!appsettings.*.Example.json

# Mobile app per-environment config (AAD tenant + client IDs, API base URL).
# Not actually secrets — public AAD facts — but kept out of the public repo
# for project-pattern consistency with appsettings*.json and to avoid
# gitleaks false positives on long random-looking strings. Committed only
# as AppConfig.cs.example.
BookTracker.Mobile/AppConfig.cs

# Bicep build output (ARM JSON is generated from .bicep on the fly)
infra/**/*.json
!infra/**/*.bicepparam

# OS
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
.DS_Store
