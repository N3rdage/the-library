@page
@model BookTracker.Web.Pages.Books.AddModel
@{
    ViewData["Title"] = "Add a book";
}

<h1 class="mb-3">Add a book</h1>

<form method="post" class="row g-4" novalidate>
    <div class="col-12">
        <div class="card">
            <div class="card-body">
                <label asp-for="Input.LookupIsbn" class="form-label fw-semibold">Look up by ISBN</label>
                <div class="input-group">
                    <input asp-for="Input.LookupIsbn" class="form-control" placeholder="9780345391803" />
                    <button type="submit" asp-page-handler="Lookup" formnovalidate class="btn btn-outline-primary">Look up</button>
                </div>
                <div class="form-text">Searches Open Library, then Google Books. Prefills the fields below — you can edit anything before saving.</div>
                @if (!string.IsNullOrEmpty(Model.LookupMessage))
                {
                    <div class="alert alert-info mt-3 mb-0 py-2">@Model.LookupMessage</div>
                }
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <div class="card h-100">
            <div class="card-header bg-white"><h2 class="h5 mb-0">Book</h2></div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-8">
                        <label asp-for="Input.Title" class="form-label"></label>
                        <input asp-for="Input.Title" class="form-control" />
                        <span asp-validation-for="Input.Title" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Input.Author" class="form-label"></label>
                        <input asp-for="Input.Author" class="form-control" />
                        <span asp-validation-for="Input.Author" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Input.Status" class="form-label"></label>
                        <select asp-for="Input.Status" asp-items="Model.StatusOptions" class="form-select"></select>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Input.Rating" class="form-label">Rating (0–5)</label>
                        <input asp-for="Input.Rating" type="number" min="0" max="5" class="form-control" />
                        <span asp-validation-for="Input.Rating" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Input.DefaultCoverArtUrl" class="form-label">Default cover URL</label>
                        <input asp-for="Input.DefaultCoverArtUrl" class="form-control" placeholder="https://..." />
                    </div>
                    <div class="col-12">
                        <label asp-for="Input.Notes" class="form-label"></label>
                        <textarea asp-for="Input.Notes" class="form-control" rows="3"></textarea>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-header bg-white"><h2 class="h5 mb-0">Cover preview</h2></div>
            <div class="card-body text-center">
                @if (!string.IsNullOrWhiteSpace(Model.Input.DefaultCoverArtUrl))
                {
                    <img src="@Model.Input.DefaultCoverArtUrl" alt="Cover preview" class="img-fluid rounded" style="max-height: 220px;" />
                }
                else
                {
                    <div class="text-muted small py-5">No cover set yet.</div>
                }
            </div>
        </div>
    </div>

    <div class="col-12">
        <div class="card">
            <div class="card-header bg-white"><h2 class="h5 mb-0">Genres</h2></div>
            <div class="card-body">
                @if (Model.ExistingGenres.Count == 0)
                {
                    <p class="text-muted small mb-3">No genres yet — add some below.</p>
                }
                else
                {
                    <div class="row row-cols-2 row-cols-md-3 row-cols-lg-4 g-2 mb-3">
                        @foreach (var g in Model.ExistingGenres)
                        {
                            var checkedAttr = Model.Input.SelectedGenreIds.Contains(g.Id) ? "checked" : null;
                            <div class="col">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="Input.SelectedGenreIds" value="@g.Id" id="genre-@g.Id" @checkedAttr />
                                    <label class="form-check-label" for="genre-@g.Id">@g.Name</label>
                                </div>
                            </div>
                        }
                    </div>
                }
                <label asp-for="Input.NewGenres" class="form-label">Additional genres (comma-separated)</label>
                <input asp-for="Input.NewGenres" class="form-control" placeholder="Science Fiction, Satire" />
                <div class="form-text">Any new names will be added to the shared genre list.</div>
            </div>
        </div>
    </div>

    <div class="col-12">
        <div class="card">
            <div class="card-header bg-white"><h2 class="h5 mb-0">First copy</h2></div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-4">
                        <label asp-for="Input.Isbn" class="form-label">ISBN</label>
                        <input asp-for="Input.Isbn" class="form-control" />
                        <span asp-validation-for="Input.Isbn" class="text-danger small"></span>
                    </div>
                    <div class="col-md-2">
                        <label asp-for="Input.Format" class="form-label"></label>
                        <select asp-for="Input.Format" asp-items="Model.FormatOptions" class="form-select"></select>
                    </div>
                    <div class="col-md-3">
                        <label asp-for="Input.DatePrinted" class="form-label">Date printed</label>
                        <input asp-for="Input.DatePrinted" type="date" class="form-control" />
                    </div>
                    <div class="col-md-3">
                        <label asp-for="Input.Condition" class="form-label"></label>
                        <select asp-for="Input.Condition" asp-items="Model.ConditionOptions" class="form-select"></select>
                    </div>
                    <div class="col-12">
                        <label asp-for="Input.CustomCoverArtUrl" class="form-label">Custom cover for this copy (optional)</label>
                        <input asp-for="Input.CustomCoverArtUrl" class="form-control" placeholder="Overrides the book's default cover" />
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12 d-flex gap-2">
        <button type="submit" asp-page-handler="Save" class="btn btn-primary">Save book</button>
        <a asp-page="/Index" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>

@section Scripts {
    @* Lookup + save share one form, so a small script tells jQuery unobtrusive validation
       to skip validation when the Look up button is clicked. Save still validates normally. *@
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('button[formnovalidate]').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    var form = btn.form;
                    if (!form) return;
                    if (window.jQuery) {
                        var v = jQuery(form).data('validator');
                        if (v) {
                            v.settings.ignore = '*';
                            v.cancelSubmit = true;
                        }
                    }
                });
            });
        });
    </script>
}
