@page "/books/bulk-add"
@implements IAsyncDisposable
@inject BulkAddViewModel VM
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject AIProviderFactory AIFactory

<PageTitle>Bulk add books - BookTracker</PageTitle>

<MudText Typo="Typo.h4" Class="mb-3">Bulk add books</MudText>

<MudCard Elevation="0" Outlined="true" Class="mb-4">
    <MudCardContent>
        @* Mobile: scanner buttons first, full-width and prominent *@
        <div class="d-md-none mb-3 d-flex gap-2">
            <MudButton Variant="Variant.Filled"
                       Color="@(scannerActive ? Color.Error : Color.Primary)"
                       OnClick="ToggleScannerAsync"
                       Class="flex-grow-1">
                @(scannerActive ? "Stop scanner" : "Scan barcode")
            </MudButton>
            <MudButton Variant="@(photoActive ? Variant.Filled : Variant.Outlined)"
                       Color="@(photoActive ? Color.Error : Color.Primary)"
                       OnClick="TogglePhotoCaptureAsync"
                       Class="flex-grow-1">
                @(photoActive ? "Cancel photo" : "Photo ISBN")
            </MudButton>
        </div>

        <div class="d-flex gap-2 align-end" data-bulk-isbn-input>
            <MudTextField T="string"
                          @bind-Value="VM.IsbnInput"
                          Label="Add ISBN"
                          Placeholder="9780345391803"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          InputMode="InputMode.numeric"
                          autocomplete="off"
                          @onkeyup="HandleIsbnKeyUp"
                          Class="flex-grow-1" />
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Primary"
                       OnClick="AddIsbnAsync"
                       Disabled="@string.IsNullOrWhiteSpace(VM.IsbnInput)">
                Add
            </MudButton>
        </div>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="d-block mt-1">
            Type or paste an ISBN and press Enter, or scan a barcode with your camera.
        </MudText>

        @* Desktop: scanner buttons below input *@
        <div class="d-none d-md-flex mt-3 gap-2">
            <MudButton Variant="@(scannerActive ? Variant.Filled : Variant.Outlined)"
                       Color="@(scannerActive ? Color.Error : Color.Default)"
                       OnClick="ToggleScannerAsync">
                @(scannerActive ? "Stop scanner" : "Scan barcode")
            </MudButton>
            <MudButton Variant="@(photoActive ? Variant.Filled : Variant.Outlined)"
                       Color="@(photoActive ? Color.Error : Color.Default)"
                       OnClick="TogglePhotoCaptureAsync">
                @(photoActive ? "Cancel photo" : "Photo ISBN")
            </MudButton>
        </div>

        <div class="mt-2">
            <AIProviderToggle />
        </div>

        @if (!string.IsNullOrEmpty(scannerError))
        {
            <MudAlert Severity="Severity.Warning" Dense="true" Class="mt-2">@scannerError</MudAlert>
        }
    </MudCardContent>
</MudCard>

@if (scannerActive)
{
    <MudCard Elevation="0" Outlined="true" Class="mb-4">
        <MudCardContent Class="text-center">
            <div id="barcode-reader" class="scanner-container"></div>
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="d-block mt-2">
                Point your camera at the ISBN barcode on the back of the book.
            </MudText>
        </MudCardContent>
    </MudCard>
}

@if (photoActive)
{
    <MudCard Elevation="0" Outlined="true" Class="mb-4">
        <MudCardContent Class="text-center">
            <div class="scanner-container">
                <video id="photo-video" autoplay playsinline muted style="width: 100%; border-radius: 0.25rem;"></video>
            </div>
            <div class="mt-2 d-flex justify-center gap-2">
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           OnClick="CapturePhotoAsync"
                           Disabled="@extractingIsbn">
                    @if (extractingIsbn)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-1" />
                        <span>Reading ISBN...</span>
                    }
                    else
                    {
                        <span>Capture</span>
                    }
                </MudButton>
            </div>
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="d-block mt-2">
                Frame the printed ISBN number and tap Capture.
            </MudText>
            @if (photoError is not null)
            {
                <MudAlert Severity="Severity.Warning" Dense="true" Class="mt-2">@photoError</MudAlert>
            }
        </MudCardContent>
    </MudCard>
}

@if (VM.Rows.Count > 0)
{
    <MudCard Elevation="0" Outlined="true" Class="mb-4">
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h6">Discovered (@VM.Rows.Count)</MudText>
            </CardHeaderContent>
            <CardHeaderActions>
                @if (VM.Rows.Any(r => r.Status == BulkAddViewModel.RowStatus.Found && !r.IsDuplicate))
                {
                    <MudButton Size="Size.Small"
                               Variant="Variant.Filled"
                               Color="Color.Success"
                               OnClick="VM.AcceptAllFoundAsync">
                        Accept all
                    </MudButton>
                }
            </CardHeaderActions>
        </MudCardHeader>

        @* Desktop table — MudTable for visual consistency with the rest of the
           Mud chrome. Per-row tinting (accepted / follow-up / duplicate states)
           via RowStyleFunc that maps RowAction to a translucent background. *@
        <div class="d-none d-md-block">
            <MudTable Items="@VM.Rows"
                      Hover="true"
                      Elevation="0"
                      Dense="false"
                      RowStyleFunc="@RowStyle">
                <HeaderContent>
                    <MudTh Style="width: 60px;"></MudTh>
                    <MudTh>ISBN</MudTh>
                    <MudTh>Title</MudTh>
                    <MudTh>Author</MudTh>
                    <MudTh>Source</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh Style="width: 280px;">Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>
                        @RenderCover(context)
                    </MudTd>
                    <MudTd Class="font-monospace" Style="font-size: 0.85rem;">@context.Isbn</MudTd>
                    <MudTd>
                        @if (context.Status == BulkAddViewModel.RowStatus.NotFound)
                        {
                            <MudTextField T="string"
                                          @bind-Value="context.Title"
                                          Placeholder="Book title..."
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense" />
                        }
                        else
                        {
                            @(context.Title ?? "—")
                        }
                        @RenderSeriesSuggestion(context)
                    </MudTd>
                    <MudTd>
                        @* Editable so multi-author and lookup-miss rows can be
                           fixed inline. Comma or "&" separates multiple authors —
                           parsed at save time via AuthorResolver.ParseNames. *@
                        <MudTextField T="string"
                                      @bind-Value="context.Author"
                                      Placeholder="Author(s) — use commas for co-authors"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense" />
                    </MudTd>
                    <MudTd>
                        @RenderSource(context)
                    </MudTd>
                    <MudTd>
                        @RenderStatusBadge(context)
                    </MudTd>
                    <MudTd>
                        <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                            @RenderActions(context)
                            <MudIconButton Size="Size.Small"
                                           Icon="@Icons.Material.Filled.Close"
                                           Color="Color.Error"
                                           OnClick="@(() => VM.RemoveRow(context))"
                                           title="Remove from grid" />
                        </MudStack>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </div>

        @* Mobile card layout *@
        <MudCardContent Class="d-md-none">
            @foreach (var row in VM.Rows)
            {
                <div class="discovery-card">
                    <div class="d-flex gap-3 align-items-start">
                        <div class="flex-shrink-0">
                            @RenderCover(row)
                        </div>
                        <div class="flex-grow-1 min-width-0">
                            <div class="d-flex justify-content-between align-items-start">
                                <div class="min-width-0">
                                    @if (row.Status == BulkAddViewModel.RowStatus.NotFound)
                                    {
                                        <MudTextField T="string"
                                                      @bind-Value="row.Title"
                                                      Placeholder="Book title..."
                                                      Variant="Variant.Outlined"
                                                      Margin="Margin.Dense"
                                                      Class="mb-1" />
                                    }
                                    else
                                    {
                                        @* Wrap multi-line on mobile rather than truncating with ellipsis —
                                           Open Library titles sometimes include format/contributor noise
                                           ("by X (Author) ON Compact Disc") and ellipsis hides useful
                                           context. text-break handles long unbroken substrings (URLs,
                                           glued-up titles like "TheArt of Discworld") that would
                                           otherwise overflow the flex container. *@
                                        <div class="fw-semibold text-break">@(row.Title ?? "—")</div>
                                    }
                                    <MudTextField T="string"
                                                  @bind-Value="row.Author"
                                                  Placeholder="Author(s) — commas for co-authors"
                                                  Variant="Variant.Outlined"
                                                  Margin="Margin.Dense"
                                                  Class="mb-1" />
                                    <div class="font-monospace text-muted" style="font-size: 0.7rem;">@row.Isbn</div>
                                </div>
                                <MudIconButton Size="Size.Small"
                                               Icon="@Icons.Material.Filled.Close"
                                               Color="Color.Error"
                                               OnClick="@(() => VM.RemoveRow(row))"
                                               title="Remove"
                                               Class="flex-shrink-0 ms-2" />
                            </div>
                            <div class="mt-2 d-flex flex-wrap gap-1 align-items-center">
                                @RenderStatusBadge(row)
                                @RenderSource(row)
                            </div>
                            <div class="mt-2">
                                @RenderActions(row)
                            </div>
                            @RenderSeriesSuggestion(row)
                        </div>
                    </div>
                </div>
            }
        </MudCardContent>
    </MudCard>
}

@* Always-visible nav back to Home — Home surfaces the running counts, which is
   the natural "OK, I'm done capturing" destination after a bulk-add session.
   Outside the rows-conditional so it's reachable even on a fresh page load. *@
<div class="mt-3">
    <MudButton Variant="Variant.Outlined" Href="/">Back to home</MudButton>
</div>

@code {
    private bool scannerActive;
    private string? scannerError;
    private DotNetObjectReference<BulkAdd>? dotNetRef;

    // Photo ISBN capture
    private bool photoActive;
    private bool extractingIsbn;
    private string? photoError;

    protected override void OnInitialized()
    {
        VM.OnStateChanged = () => InvokeAsync(StateHasChanged);
    }

    private async Task HandleIsbnKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await AddIsbnAsync();
    }

    private async Task AddIsbnAsync()
    {
        await VM.AddIsbnAsync();
        StateHasChanged();
    }

    private async Task TogglePhotoCaptureAsync()
    {
        photoError = null;
        if (photoActive)
        {
            try { await JS.InvokeVoidAsync("PhotoCapture.stop"); } catch { }
            photoActive = false;
        }
        else
        {
            // Stop barcode scanner if active
            if (scannerActive)
            {
                await JS.InvokeVoidAsync("BarcodeScanner.stop");
                scannerActive = false;
            }

            photoActive = true;
            StateHasChanged();
            await Task.Delay(200);

            try
            {
                var started = await JS.InvokeAsync<bool>("PhotoCapture.start", "photo-video");
                if (!started)
                {
                    photoError = "Could not access camera. Check permissions.";
                    photoActive = false;
                }
            }
            catch (Exception ex)
            {
                photoError = $"Camera error: {ex.Message}";
                photoActive = false;
            }
        }
    }

    private async Task CapturePhotoAsync()
    {
        extractingIsbn = true;
        photoError = null;

        try
        {
            var base64 = await JS.InvokeAsync<string?>("PhotoCapture.capture", "photo-video");
            if (string.IsNullOrEmpty(base64))
            {
                photoError = "Failed to capture image. Make sure the camera is active.";
                return;
            }

            var isbn = await AIFactory.GetService().ExtractIsbnFromImageAsync(base64);
            if (isbn is null)
            {
                photoError = "Could not find an ISBN in the photo. Try again with clearer framing.";
                return;
            }

            // Feed the extracted ISBN into the discovery grid
            VM.IsbnInput = isbn;
            await VM.AddIsbnAsync();

            // Camera stays live so the user can capture the next book in
            // the batch without re-opening it. The "Cancel photo" button
            // explicitly stops the stream when they're done.
        }
        catch (Exception ex)
        {
            photoError = $"Error: {ex.Message}";
        }
        finally
        {
            extractingIsbn = false;
        }
    }

    private async Task ToggleScannerAsync()
    {
        scannerError = null;
        if (scannerActive)
        {
            await JS.InvokeVoidAsync("BarcodeScanner.stop");
            scannerActive = false;
        }
        else
        {
            // Stop photo capture if active
            if (photoActive)
            {
                await JS.InvokeVoidAsync("PhotoCapture.stop");
                photoActive = false;
            }

            scannerActive = true;
            dotNetRef ??= DotNetObjectReference.Create(this);
            StateHasChanged();
            await Task.Delay(100);
            await JS.InvokeVoidAsync("BarcodeScanner.start", "barcode-reader", dotNetRef);
        }
    }

    [JSInvokable]
    public async Task OnBarcodeScanned(string decodedText)
    {
        var isbn = decodedText.Trim();
        if (string.IsNullOrWhiteSpace(isbn)) return;

        if (VM.Rows.Any(r => string.Equals(r.Isbn, isbn, StringComparison.OrdinalIgnoreCase)))
            return;

        await InvokeAsync(async () =>
        {
            VM.IsbnInput = isbn;
            await VM.AddIsbnAsync();
            StateHasChanged();
        });
    }

    [JSInvokable]
    public async Task OnScannerError(string error)
    {
        await InvokeAsync(() =>
        {
            scannerError = $"Camera error: {error}";
            scannerActive = false;
            StateHasChanged();
        });
    }

    public async ValueTask DisposeAsync()
    {
        if (scannerActive)
        {
            try { await JS.InvokeVoidAsync("BarcodeScanner.stop"); } catch { }
        }
        if (photoActive)
        {
            try { await JS.InvokeVoidAsync("PhotoCapture.stop"); } catch { }
        }
        dotNetRef?.Dispose();
    }

    // Per-row background tint for MudTable rows, mirroring the previous
    // Bootstrap table-success / table-warning / table-secondary classes.
    // Translucent colours so the underlying row hover still reads.
    private string RowStyle(BulkAddViewModel.DiscoveryRow row, int rowIndex) => row.Action switch
    {
        BulkAddViewModel.RowAction.Accepted => "background-color: rgba(76, 175, 80, 0.10);",
        BulkAddViewModel.RowAction.FollowUp => "background-color: rgba(255, 152, 0, 0.10);",
        BulkAddViewModel.RowAction.Duplicate => "background-color: rgba(158, 158, 158, 0.10);",
        _ => ""
    };

    private RenderFragment RenderCover(BulkAddViewModel.DiscoveryRow row) => __builder =>
    {
        if (!string.IsNullOrWhiteSpace(row.CoverUrl))
        {
            <MudImage Src="@row.CoverUrl"
                      Alt=""
                      loading="lazy"
                      decoding="async"
                      Class="rounded"
                      Style="width: 40px; height: 56px; object-fit: cover;" />
        }
        else
        {
            <div class="rounded d-flex align-items-center justify-content-center" style="width: 40px; height: 56px; background: var(--mud-palette-background-grey);">
                <span class="text-muted small">--</span>
            </div>
        }
    };

    private RenderFragment RenderSource(BulkAddViewModel.DiscoveryRow row) => __builder =>
    {
        if (row.Status == BulkAddViewModel.RowStatus.Searching)
        {
            <MudProgressCircular Size="Size.Small" Indeterminate="true" />
        }
        else if (row.Source is not null)
        {
            <MudText Typo="Typo.caption" Color="Color.Secondary">@row.Source</MudText>
        }
    };

    private RenderFragment RenderStatusBadge(BulkAddViewModel.DiscoveryRow row) => __builder =>
    {
        // Accepted / FollowUp rows are removed from the grid on action, so only
        // Pending and Duplicate-skip states are reachable here.
        if (row.Action == BulkAddViewModel.RowAction.Duplicate)
        {
            <MudChip T="string" Size="Size.Small" Color="Color.Default">Duplicate</MudChip>
        }
        else if (row.IsDuplicate)
        {
            <MudChip T="string" Size="Size.Small" Color="Color.Warning">In library</MudChip>
        }
        else
        {
            switch (row.Status)
            {
                case BulkAddViewModel.RowStatus.Found:
                    <MudChip T="string" Size="Size.Small" Color="Color.Info">Found</MudChip>
                    break;
                case BulkAddViewModel.RowStatus.NotFound:
                    <MudChip T="string" Size="Size.Small" Color="Color.Error">Not found</MudChip>
                    break;
                case BulkAddViewModel.RowStatus.Searching:
                    <MudChip T="string" Size="Size.Small" Color="Color.Default">Searching...</MudChip>
                    break;
            }
        }
    };

    private RenderFragment RenderSeriesSuggestion(BulkAddViewModel.DiscoveryRow row) => __builder =>
    {
        if (row.SeriesSuggestion is null || row.Action != BulkAddViewModel.RowAction.Pending) return;

        @* Two visual states per row, mirroring Add Book:
           - Pending: warning text + Accept (only for API-sourced reasons).
           - Accepted: success text + Undo. *@
        if (row.SeriesSuggestionAccepted)
        {
            <div class="text-success small mt-1 text-break d-flex align-items-start gap-2 flex-wrap">
                <span>
                    <strong>✓ Series:</strong> @row.AcceptedSeriesName
                    @if (row.AcceptedSeriesOrder is int order)
                    {
                        <span> #@order</span>
                    }
                    @if (row.AcceptedSeriesId is null)
                    {
                        <span class="text-muted"> (will be created)</span>
                    }
                </span>
                <MudButton Size="Size.Small" Variant="Variant.Text" OnClick="@(() => VM.UndoSeriesSuggestionAccept(row))">Undo</MudButton>
            </div>
        }
        else
        {
            <div class="text-warning small mt-1 text-break d-flex align-items-start gap-2 flex-wrap">
                <span>
                    <strong>Series:</strong> @row.SeriesSuggestion.Message
                    @if (row.SeriesSuggestion.SeriesId.HasValue)
                    {
                        <MudLink Href="@($"/series/{row.SeriesSuggestion.SeriesId}")" Class="ms-1" Target="_blank">View</MudLink>
                    }
                </span>
                @if (row.SeriesSuggestion.Reason is MatchReason.ApiMatchExisting or MatchReason.ApiMatchNewSeries)
                {
                    <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Success" OnClick="@(() => VM.AcceptSeriesSuggestion(row))">Accept</MudButton>
                }
            </div>
        }
    };

    private RenderFragment RenderActions(BulkAddViewModel.DiscoveryRow row) => __builder =>
    {
        if (row.Action == BulkAddViewModel.RowAction.Pending)
        {
            if (row.Status == BulkAddViewModel.RowStatus.Found)
            {
                <MudStack Row="true" Spacing="1">
                    @if (row.IsDuplicate)
                    {
                        <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Success" OnClick="@(() => VM.AcceptRowAsync(row))" title="Add another copy">
                            Add copy
                        </MudButton>
                        <MudButton Size="Size.Small" Variant="Variant.Outlined" OnClick="@(() => row.Action = BulkAddViewModel.RowAction.Duplicate)" title="Skip duplicate">
                            Skip
                        </MudButton>
                    }
                    else
                    {
                        <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Success" OnClick="@(() => VM.AcceptRowAsync(row))">
                            Accept
                        </MudButton>
                    }
                    <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Warning" OnClick="@(() => VM.FollowUpRowAsync(row))">
                        Follow-up
                    </MudButton>
                </MudStack>
            }
            else if (row.Status == BulkAddViewModel.RowStatus.NotFound)
            {
                <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Warning" OnClick="@(() => VM.FollowUpNotFoundAsync(row))">
                    Add as follow-up
                </MudButton>
            }
        }
        else
        {
            <MudText Typo="Typo.caption" Color="Color.Secondary">Done</MudText>
        }
    };
}
