@page "/books/add"
@implements IAsyncDisposable
@inject BookAddViewModel VM
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject IDialogService DialogService
@inject ILogger<Add> Logger

<PageTitle>Add a book - BookTracker</PageTitle>

<MudText Typo="Typo.h4" Class="mb-3">Add a book</MudText>

<EditForm Model="this" OnValidSubmit="SaveAsync" FormName="addBook">
    <DataAnnotationsValidator />

    <MudGrid Spacing="4">
        <MudItem xs="12">
            <MudCard Elevation="0" Outlined="true">
                <MudCardContent>
                    <MudSwitch T="bool"
                               Value="VM.NoIsbnMode"
                               ValueChanged="@(v => VM.NoIsbnMode = v)"
                               Color="Color.Primary"
                               Label="No ISBN (pre-1974 book)" />
                    @* Custom ValueChanged instead of @bind because flipping the toggle OFF when
                       any row is an attach-existing reference would silently discard those
                       attachments — confirm first so a fat-finger flick is recoverable. *@
                    <MudSwitch T="bool"
                               Value="VM.IsCollection"
                               ValueChanged="@OnCollectionToggleChangedAsync"
                               Color="Color.Primary"
                               Label="This is a collection (multiple works in one book)"
                               Class="mb-3" />

                    @if (!VM.NoIsbnMode)
                    {
                        @* Wrapper attribute lets book-form-keys.js route Enter on the
                           ISBN input to OnIsbnLookupEnter — without the data-attr the
                           document-level keydown listener ignores it and Enter falls
                           through to the surrounding EditForm's submit handler, which
                           would then call SaveAsync on an empty form. *@
                        <div class="d-flex gap-2 align-end" data-isbn-lookup-input>
                            <MudTextField T="string"
                                          @bind-Value="VM.LookupIsbn"
                                          Label="Look up by ISBN"
                                          Placeholder="9780345391803"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Class="flex-grow-1" />
                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Primary"
                                       OnClick="LookupAsync"
                                       Disabled="@VM.LookingUp"
                                       StartIcon="@(VM.LookingUp ? null : null)">
                                @if (VM.LookingUp)
                                {
                                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2" />
                                }
                                Look up
                            </MudButton>
                        </div>
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="d-block mt-1">
                            Searches Open Library, then Google Books. Prefills the fields below — you can edit anything before saving.
                        </MudText>
                    }
                    else
                    {
                        <MudText Typo="Typo.subtitle2" Class="mb-2">Search by title and/or author</MudText>
                        <MudGrid Spacing="2">
                            <MudItem xs="12" md="5">
                                <MudTextField T="string"
                                              @bind-Value="VM.SearchTitle"
                                              Placeholder="Title"
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense" />
                            </MudItem>
                            <MudItem xs="12" md="5">
                                <MudTextField T="string"
                                              @bind-Value="VM.SearchAuthor"
                                              Placeholder="Author"
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense" />
                            </MudItem>
                            <MudItem xs="12" md="2">
                                <MudButton Variant="Variant.Outlined"
                                           Color="Color.Primary"
                                           OnClick="SearchAsync"
                                           Disabled="@VM.Searching"
                                           FullWidth="true">
                                    @if (VM.Searching)
                                    {
                                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2" />
                                    }
                                    Search
                                </MudButton>
                            </MudItem>
                        </MudGrid>
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="d-block mt-1">
                            Searches Open Library by title/author. Pick a candidate to prefill — you'll need to fill format, exact print date, and publisher from the book in hand.
                        </MudText>

                        @if (VM.SearchCandidates.Count > 0)
                        {
                            <MudStack Spacing="2" Class="mt-3">
                                @foreach (var candidate in VM.SearchCandidates)
                                {
                                    <MudPaper Outlined="true" Class="pa-2">
                                        <MudStack Row="true" Spacing="3" AlignItems="AlignItems.Center">
                                            @if (!string.IsNullOrEmpty(candidate.CoverUrl))
                                            {
                                                <MudImage Src="@candidate.CoverUrl"
                                                          Alt=""
                                                          loading="lazy"
                                                          decoding="async"
                                                          Style="width: 48px; height: 72px; object-fit: cover;" />
                                            }
                                            else
                                            {
                                                <div style="width: 48px; height: 72px; background: #eee;"></div>
                                            }
                                            <MudStack Spacing="0" Class="flex-grow-1" Style="min-width: 0;">
                                                <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">@candidate.Title</MudText>
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                    @candidate.Author
                                                    @if (candidate.FirstPublishYear.HasValue)
                                                    {
                                                        <span> &middot; first published @candidate.FirstPublishYear</span>
                                                    }
                                                    @if (candidate.EditionCount is int n && n > 0)
                                                    {
                                                        <span> &middot; @n edition@(n == 1 ? "" : "s") on file</span>
                                                    }
                                                </MudText>
                                                @if (!string.IsNullOrEmpty(candidate.OpenLibraryUrl))
                                                {
                                                    <MudLink Href="@candidate.OpenLibraryUrl" Target="_blank" Typo="Typo.caption">
                                                        Show all editions on Open Library &rarr;
                                                    </MudLink>
                                                }
                                            </MudStack>
                                            <MudButton Size="Size.Small"
                                                       Variant="Variant.Filled"
                                                       Color="Color.Primary"
                                                       OnClick="@(() => ApplyCandidateAsync(candidate))">
                                                Use this
                                            </MudButton>
                                        </MudStack>
                                    </MudPaper>
                                }
                            </MudStack>
                        }
                    }

                    @if (VM.ExistingBook is not null)
                    {
                        <MudAlert Severity="Severity.Warning" Class="mt-3" Dense="true">
                            <MudText Typo="Typo.subtitle2">You already own this book.</MudText>
                            <MudText Typo="Typo.body2" Class="mb-2">
                                <strong>@VM.ExistingBook.Title</strong> by @VM.ExistingBook.Author —
                                @VM.ExistingBook.CopyCount cop@(VM.ExistingBook.CopyCount == 1 ? "y" : "ies") on file.
                            </MudText>
                            <MudStack Row="true" Spacing="2">
                                <MudButton Size="Size.Small"
                                           Variant="Variant.Filled"
                                           Color="Color.Success"
                                           OnClick="AddCopyAsync"
                                           Disabled="@VM.AddingCopy">
                                    @if (VM.AddingCopy)
                                    {
                                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-1" />
                                    }
                                    Add another copy
                                </MudButton>
                                <MudButton Size="Size.Small"
                                           Variant="Variant.Outlined"
                                           Color="Color.Primary"
                                           Href="@($"/books/{VM.ExistingBook.BookId}")">
                                    View existing book
                                </MudButton>
                            </MudStack>
                        </MudAlert>
                    }
                    @{
                        var lookupMsg = VM.NoIsbnMode ? VM.SearchMessage : VM.LookupMessage;
                    }
                    @if (!string.IsNullOrEmpty(lookupMsg))
                    {
                        <MudAlert Severity="Severity.Info" Class="mt-3" Dense="true">@lookupMsg</MudAlert>
                    }
                    @if (VM.SeriesSuggestion is not null && !VM.SeriesSuggestionDismissed)
                    {
                        @* Two visual states:
                           - Pending (default): show the suggestion message + Accept / dismiss
                             buttons (Accept only for actionable API-sourced reasons).
                           - Accepted: show "✓ Will attach" with the series name + an Undo
                             button. Dismiss (×) still available alongside Undo. *@
                        <MudAlert Severity="@(VM.SeriesSuggestionAccepted ? Severity.Success : Severity.Warning)"
                                  Class="mt-3"
                                  Dense="true"
                                  ShowCloseIcon="true"
                                  CloseIconClicked="() => VM.SeriesSuggestionDismissed = true">
                            <MudStack Row="true" Spacing="2" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start">
                                <div class="text-break">
                                    @if (VM.SeriesSuggestionAccepted)
                                    {
                                        <strong>✓ Will attach to series:</strong>
                                        <span>@VM.AcceptedSeriesName</span>
                                        @if (VM.AcceptedSeriesOrder is int order)
                                        {
                                            <span> #@order</span>
                                        }
                                        @if (VM.AcceptedSeriesId is null)
                                        {
                                            <span class="mud-typography-caption mud-text-secondary"> (will be created on save)</span>
                                        }
                                    }
                                    else
                                    {
                                        <strong>Series suggestion:</strong>
                                        <span>@VM.SeriesSuggestion.Message</span>
                                        @if (VM.SeriesSuggestion.SeriesId.HasValue)
                                        {
                                            <span> &mdash; <MudLink Href="@($"/series/{VM.SeriesSuggestion.SeriesId}")" Target="_blank">View series</MudLink></span>
                                        }
                                    }
                                </div>
                                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center" Class="flex-shrink-0">
                                    @if (VM.SeriesSuggestionAccepted)
                                    {
                                        <MudButton Size="Size.Small" Variant="Variant.Outlined" OnClick="VM.UndoSeriesSuggestionAccept">Undo</MudButton>
                                    }
                                    else if (VM.SeriesSuggestion.Reason is MatchReason.ApiMatchExisting or MatchReason.ApiMatchNewSeries)
                                    {
                                        <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Success" OnClick="VM.AcceptSeriesSuggestion">Accept</MudButton>
                                    }
                                </MudStack>
                            </MudStack>
                        </MudAlert>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>

        <MudItem xs="12">
            <BookForm Input="VM.BookInput" />
        </MudItem>

        @if (!VM.IsCollection)
        {
            <MudItem xs="12">
                <WorkForm Input="VM.WorkInput" Title="Work (story / novel)" />
            </MudItem>

            <MudItem xs="12">
                <MudCard Elevation="0" Outlined="true">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Genres</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="d-block mb-2">Genres apply to the work above.</MudText>
                        <MudGenrePicker @ref="genrePicker"
                                        SelectedGenreIds="selectedGenreIds"
                                        SelectedGenreIdsChanged="ids => selectedGenreIds = ids"
                                        LookupCandidates="VM.LookupCandidates" />
                    </MudCardContent>
                </MudCard>
            </MudItem>
        }
        else
        {
            <MudItem xs="12">
                <MudCard Elevation="0" Outlined="true">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Works in this collection</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        @* Single-Author + Single-Genre modes — when on,
                           render a shared picker at the top; per-row
                           pickers are hidden and save applies the shared
                           list to every Work. Common case (Drew's order-
                           of-magnitude driver for genres: a 20-work
                           anthology where 19 share a single genre); same
                           shape for authors. State is sticky across
                           toggle flips — per-row entries don't get
                           clobbered if the user toggles on then off. *@
                        <MudSwitch T="bool"
                                   @bind-Value="VM.SingleAuthor"
                                   Color="Color.Primary"
                                   Label="Same author(s) for all works" />
                        <MudSwitch T="bool"
                                   @bind-Value="VM.SingleGenre"
                                   Color="Color.Primary"
                                   Label="Same genre(s) for all works"
                                   Class="mb-3" />

                        @if (VM.SingleAuthor)
                        {
                            <div class="mb-3">
                                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="d-block mb-1">Author(s) for all works in this collection</MudText>
                                <MudAuthorPicker Authors="VM.SharedAuthors"
                                                 AuthorsChanged="list => VM.SharedAuthors = list"
                                                 Label="Add author" />
                            </div>
                        }

                        @if (VM.SingleGenre)
                        {
                            <div class="mb-3">
                                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="d-block mb-1">Genre(s) for all works in this collection</MudText>
                                <MudGenrePicker SelectedGenreIds="VM.SharedGenreIds"
                                                SelectedGenreIdsChanged="ids => VM.SharedGenreIds = ids" />
                            </div>
                        }

                        @for (var i = 0; i < VM.CollectionWorks.Count; i++)
                        {
                            var index = i;
                            var work = VM.CollectionWorks[i];
                            @if (work.AttachedWorkId is int)
                            {
                                @* Attach-existing summary card. Editable fields hidden; the existing Work
                                   carries its own authors / subtitle / first-published / genres. "Edit as new"
                                   reverts to the new-work shape preserving whatever title was typed. *@
                                <MudPaper Outlined="true" Class="pa-3 mb-3" Style="background: var(--mud-palette-background-grey);">
                                    <MudStack Row="true" Spacing="2" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start">
                                        <div class="flex-grow-1" style="min-width: 0;">
                                            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="mb-1" Wrap="Wrap.Wrap">
                                                <MudChip T="string" Size="Size.Small" Color="Color.Default">Existing work</MudChip>
                                                <strong style="word-break: break-word;">@work.Title</strong>
                                            </MudStack>
                                            @if (!string.IsNullOrEmpty(work.AttachedWorkAuthor))
                                            {
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">@work.AttachedWorkAuthor</MudText>
                                            }
                                        </div>
                                        <MudStack Row="true" Spacing="1" Class="flex-shrink-0">
                                            <MudButton Size="Size.Small" Variant="Variant.Outlined" OnClick="() => VM.DetachRow(index)">Edit as new</MudButton>
                                            @if (VM.CollectionWorks.Count > 1)
                                            {
                                                <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Error" OnClick="() => VM.RemoveCollectionWorkRow(index)">Remove</MudButton>
                                            }
                                        </MudStack>
                                    </MudStack>
                                </MudPaper>
                            }
                            else
                            {
                                <MudPaper Outlined="true" Class="pa-3 mb-3">
                                    <MudStack Row="true" Spacing="2" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-2">
                                        <strong>Work @(index + 1)</strong>
                                        @if (VM.CollectionWorks.Count > 1)
                                        {
                                            <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Error" OnClick="() => VM.RemoveCollectionWorkRow(index)">Remove</MudButton>
                                        }
                                    </MudStack>
                                    <MudGrid Spacing="2">
                                        <MudItem xs="12" md="@(VM.SingleAuthor ? 12 : 7)">
                                            @* MudAutocomplete<WorkSearchResult> — as the user types, existing
                                               Works appear in the dropdown. Picking one fires ValueChanged →
                                               OnExistingWorkPickedAsync, flipping the row to attach-existing
                                               mode. Free-text Enter (no dropdown highlight) falls through to
                                               book-form-keys.js → page [JSInvokable] OnCollectionTitleEnter,
                                               which adds a new row / focuses next. The wrapper div carries
                                               data-collection-work-title="@index" so the JS doc-level keydown
                                               listener can route the event correctly — MudAutocomplete renders
                                               its <input> deep inside, so we can't put the data-attribute
                                               directly on the input. *@
                                            <div data-collection-work-title="@index">
                                                @* CoerceText="false" so Esc / un-picked dropdown close doesn't
                                                   revert work.Title to the (null) Value's display string —
                                                   the typed text needs to survive for the "captured as new"
                                                   flow. Paired with the book-form-keys.js capture-phase
                                                   listener that tracks user navigation (Down/Up) per input
                                                   and only defers to MudAutocomplete's auto-pick when the
                                                   user has explicitly arrow-keyed. *@
                                                <MudAutocomplete T="WorkSearchResult"
                                                                 Value="null"
                                                                 ValueChanged="@(picked => OnExistingWorkPickedAsync(picked, index))"
                                                                 Text="@work.Title"
                                                                 TextChanged="@(t => work.Title = t ?? string.Empty)"
                                                                 SearchFunc="@(async (q, ct) => await SearchExistingWorksAsync(q, ct))"
                                                                 ToStringFunc="@(r => r?.Title ?? string.Empty)"
                                                                 Label="Title"
                                                                 Placeholder="Type to search existing or capture new..."
                                                                 Variant="Variant.Outlined"
                                                                 Margin="Margin.Dense"
                                                                 MinCharacters="2"
                                                                 DebounceInterval="250"
                                                                 CoerceValue="false"
                                                                 CoerceText="false"
                                                                 ResetValueOnEmptyText="false"
                                                                 ShowProgressIndicator="true">
                                                    <ItemTemplate Context="r">
                                                        <MudStack Spacing="0" Style="min-width: 0;">
                                                            <MudText Typo="Typo.body2" Style="word-break: break-word;">
                                                                @r.Title@(r.FirstPublishedYear is int y ? $" ({y})" : "")
                                                            </MudText>
                                                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                                @r.AuthorName · in @r.BookCount @(r.BookCount == 1 ? "book" : "books")
                                                            </MudText>
                                                        </MudStack>
                                                    </ItemTemplate>
                                                </MudAutocomplete>
                                            </div>
                                        </MudItem>
                                        @if (!VM.SingleAuthor)
                                        {
                                            <MudItem xs="12" md="5">
                                                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="d-block mb-1">Author(s)</MudText>
                                                <MudAuthorPicker Authors="work.Authors"
                                                                 AuthorsChanged="list => work.Authors = list"
                                                                 Label="Add author" />
                                            </MudItem>
                                        }
                                        <MudItem xs="12" md="7">
                                            <MudTextField T="string"
                                                          @bind-Value="work.Subtitle"
                                                          Label="Subtitle (optional)"
                                                          Variant="Variant.Outlined"
                                                          Margin="Margin.Dense" />
                                        </MudItem>
                                        <MudItem xs="12" md="5">
                                            <MudTextField T="string"
                                                          @bind-Value="work.FirstPublishedDate"
                                                          Label="First published (optional)"
                                                          Placeholder="e.g. 1934"
                                                          Variant="Variant.Outlined"
                                                          Margin="Margin.Dense" />
                                        </MudItem>
                                        @if (!VM.SingleGenre)
                                        {
                                            <MudItem xs="12">
                                                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="d-block mb-1">Genre(s)</MudText>
                                                <MudGenrePicker SelectedGenreIds="work.GenreIds"
                                                                SelectedGenreIdsChanged="ids => work.GenreIds = ids" />
                                            </MudItem>
                                        }
                                    </MudGrid>
                                </MudPaper>
                            }
                        }
                        <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary" OnClick="VM.AddCollectionWorkRow">
                            + Add another work
                        </MudButton>
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="d-block mt-2">
                            Start typing a title and any matching existing Works appear — Enter on a highlighted match attaches it; press Enter on free text to add the next new row.
                        </MudText>
                    </MudCardContent>
                </MudCard>
            </MudItem>
        }

        <MudItem xs="12">
            <EditionCopyForm EditionInput="VM.EditionInput" CopyInput="VM.CopyInput" Title="First edition & copy" />
        </MudItem>

        @if (!string.IsNullOrEmpty(saveErrorMessage))
        {
            <MudItem xs="12">
                <MudAlert Severity="Severity.Error" Dense="true">@saveErrorMessage</MudAlert>
            </MudItem>
        }

        <MudItem xs="12">
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
                <MudButton ButtonType="ButtonType.Submit"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           Disabled="@VM.Saving">
                    @if (VM.Saving)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2" />
                    }
                    Save book
                </MudButton>
                <MudButton Variant="Variant.Outlined" Href="/">Cancel</MudButton>
                <MudCheckBox T="bool" @bind-Value="addAnother" Color="Color.Primary" Label="Add another?" />
            </MudStack>
        </MudItem>
    </MudGrid>
</EditForm>

@code {
    private List<int> selectedGenreIds = [];
    private MudGenrePicker? genrePicker;
    private bool addAnother;

    // Save-error surface for #44 — when VM.SaveAsync throws, the
    // catch in SaveAsync below stashes the user-facing message here
    // so the alert above the Save button renders it. Cleared at the
    // start of each Save attempt; not cleared on field edit (the user
    // can read the message AND keep typing — clearing on every keypress
    // would just flash the alert away mid-correction).
    private string? saveErrorMessage;

    // After Enter on a title grows the CollectionWorks list (or an
    // existing-Work pick advances to the next row), the new row's DOM
    // element only exists post-render. Stash the index here and apply
    // focus in OnAfterRenderAsync so the JS focus call hits an element
    // that actually exists.
    private int? _pendingCollectionFocusIndex;

    // DotNetObjectReference handed to book-form-keys.js so the JS
    // keydown listener can call back into Blazor with the row index
    // when Enter fires on a non-highlighted Title (the "add new row /
    // focus next" path). Disposed on circuit teardown so the listener
    // can't call a dead managed object.
    private DotNetObjectReference<Add>? _pageRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _pageRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("bookFormKeys.bindEnterSuppression", _pageRef);
        }

        if (_pendingCollectionFocusIndex is int idx)
        {
            _pendingCollectionFocusIndex = null;
            await JS.InvokeVoidAsync("bookFormKeys.focusTitle", idx);
        }
    }

    public ValueTask DisposeAsync()
    {
        _pageRef?.Dispose();
        return ValueTask.CompletedTask;
    }

    /// <summary>Invoked by book-form-keys.js when Enter fires on the
    /// ISBN lookup input. Same effect as clicking "Look up".</summary>
    [JSInvokable]
    public Task OnIsbnLookupEnter() => LookupAsync();

    /// <summary>Invoked by book-form-keys.js when Enter fires on a
    /// title input AND no autocomplete suggestion is highlighted —
    /// equivalent to the old @onkeydown handler's last-row vs mid-list
    /// behaviour. Existing-Work rows have no input (they render as a
    /// summary), so the JS listener never targets them.</summary>
    [JSInvokable]
    public async Task OnCollectionTitleEnter(int index)
    {
        if (!VM.IsCollection) return;
        if (index < 0 || index >= VM.CollectionWorks.Count) return;

        if (index == VM.CollectionWorks.Count - 1)
        {
            VM.AddCollectionWorkRow();
            _pendingCollectionFocusIndex = VM.CollectionWorks.Count - 1;
            await InvokeAsync(StateHasChanged);
        }
        else
        {
            await JS.InvokeVoidAsync("bookFormKeys.focusTitle", index + 1);
        }
    }

    /// <summary>Fired when the user picks a suggestion from the row's
    /// title autocomplete (Enter on a highlighted item, or click).
    /// Flips the row to attach-existing mode and advances focus to
    /// the next row's title — same continuation as Enter-on-free-text,
    /// so the keyboard flow doesn't break stride after a pick.</summary>
    private async Task OnExistingWorkPickedAsync(WorkSearchResult? picked, int index)
    {
        if (picked is null) return;
        if (!VM.IsCollection) return;
        if (index < 0 || index >= VM.CollectionWorks.Count) return;

        VM.AttachExistingToRow(index, picked);

        if (index == VM.CollectionWorks.Count - 1)
        {
            VM.AddCollectionWorkRow();
        }
        _pendingCollectionFocusIndex = index + 1;
        await InvokeAsync(StateHasChanged);
    }

    private async Task<IEnumerable<WorkSearchResult>> SearchExistingWorksAsync(string? query, CancellationToken ct)
    {
        try { return await VM.SearchExistingWorksAsync(query ?? "", ct); }
        catch { return []; }
    }

    /// <summary>Custom toggle handler for the collection switch — confirms
    /// before flipping OFF when there are existing-Work attachments on
    /// rows (a fat-finger flick would otherwise silently drop them, since
    /// the single-Work form has nowhere to put attachments).</summary>
    private async Task OnCollectionToggleChangedAsync(bool newValue)
    {
        if (newValue == VM.IsCollection) return;

        if (!newValue && VM.HasAttachedWorkRows)
        {
            var attachedCount = VM.CollectionWorks.Count(r => r.AttachedWorkId is not null);
            var confirmed = await DialogService.ShowMessageBoxAsync(
                "Discard attached works?",
                $"Switching off collection mode will discard {attachedCount} existing-work attachment{(attachedCount == 1 ? "" : "s")}. Continue?",
                yesText: "Discard",
                cancelText: "Keep collection mode");
            if (confirmed != true)
            {
                // Confirm cancelled — re-render so the switch snaps back
                // to ON.
                await InvokeAsync(StateHasChanged);
                return;
            }
        }

        VM.IsCollection = newValue;
        await InvokeAsync(StateHasChanged);
    }

    private async Task LookupAsync()
    {
        await VM.LookupAsync();
        // After the VM updates LookupCandidates, the picker's parameter
        // binding pushes the new list in. ApplyCandidatesAsync then
        // fuzzy-matches + auto-selects matches. Explicit call so manual
        // genre removals after this stick (re-renders don't re-apply).
        if (genrePicker is not null)
        {
            await genrePicker.ApplyCandidatesAsync(VM.LookupCandidates);
        }
    }

    private async Task SearchAsync()
    {
        await VM.SearchAsync();
    }

    private async Task ApplyCandidateAsync(BookSearchCandidate candidate)
    {
        await VM.ApplyCandidateAsync(candidate);
    }

    private async Task SaveAsync()
    {
        saveErrorMessage = null;
        int? savedId;
        try
        {
            savedId = await VM.SaveAsync(selectedGenreIds);
        }
        catch (InvalidOperationException ex)
        {
            // Deliberate VM throws for validation-style problems —
            // missing authors, collection rows without title/author etc.
            // Messages are user-facing by construction; surface as-is.
            saveErrorMessage = ex.Message;
            return;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unexpected error saving book from Add page");
            saveErrorMessage = "Save failed — your input is preserved. Try again, or see logs for details.";
            return;
        }

        if (savedId is null) return;

        if (addAnother)
        {
            ResetForNextBook();
        }
        else
        {
            Nav.NavigateTo("/");
        }
    }

    private async Task AddCopyAsync()
    {
        var bookId = await VM.AddCopyToExistingAsync();
        if (bookId is null) return;

        if (addAnother)
        {
            ResetForNextBook();
        }
        else
        {
            Nav.NavigateTo($"/books/{bookId}");
        }
    }

    private void ResetForNextBook()
    {
        VM.Reset();
        selectedGenreIds = [];
        // Picker re-renders via parameter binding when selectedGenreIds
        // + VM.LookupCandidates reset above. No direct picker poke needed.
        StateHasChanged();
    }
}
