@inject AIProviderFactory ProviderFactory

<MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="d-inline-flex">
    <MudSelect T="AIProvider"
               Value="ProviderFactory.ActiveProvider"
               ValueChanged="OnProviderChanged"
               Dense="true"
               Variant="Variant.Outlined"
               Margin="Margin.Dense"
               Style="min-width: 220px;">
        @foreach (var provider in ProviderFactory.AvailableProviders)
        {
            <MudSelectItem T="AIProvider" Value="@provider">@FormatProvider(provider)</MudSelectItem>
        }
    </MudSelect>
    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">
        @ProviderFactory.GetService().CallCount calls
    </MudChip>
</MudStack>

@code {
    [Parameter]
    public EventCallback OnChanged { get; set; }

    private async Task OnProviderChanged(AIProvider provider)
    {
        ProviderFactory.SwitchProvider(provider);
        await OnChanged.InvokeAsync();
    }

    private static string FormatProvider(AIProvider p) => p switch
    {
        AIProvider.Anthropic => "Anthropic (Claude)",
        AIProvider.MicrosoftFoundry => "Microsoft Foundry (Claude)",
        AIProvider.AzureOpenAI => "Azure OpenAI (GPT-4o)",
        _ => p.ToString()
    };
}
