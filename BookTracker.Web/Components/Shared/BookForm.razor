@* Book-level fields (title, category, status, rating, cover URL, notes)
   plus a live cover preview pane alongside. Used on the Add Book page.
   Validation flows from the parent page's DataAnnotationsValidator via
   the For="..." expressions on each MudTextField. *@

<MudGrid Spacing="3">
    <MudItem xs="12" md="8">
        <MudCard Elevation="0" Outlined="true" Class="h-100">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">Book</MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <MudGrid Spacing="3">
                    <MudItem xs="12">
                        <MudTextField T="string"
                                      @bind-Value="Input.Title"
                                      For="@(() => Input.Title)"
                                      Label="Title"
                                      HelperText="For single-work books this mirrors the work's title. For compendiums, this is the book's own title (e.g. 'Best of Christie')."
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="12" md="3">
                        <MudSelect T="BookCategory"
                                   @bind-Value="Input.Category"
                                   Label="Category"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense">
                            @foreach (var c in Enum.GetValues<BookCategory>())
                            {
                                <MudSelectItem T="BookCategory" Value="@c">@BookFormViewModel.FormatCategory(c)</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="3">
                        <MudSelect T="BookStatus"
                                   @bind-Value="Input.Status"
                                   Label="Status"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense">
                            @foreach (var s in Enum.GetValues<BookStatus>())
                            {
                                <MudSelectItem T="BookStatus" Value="@s">@s</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="3">
                        <MudNumericField T="int"
                                         @bind-Value="Input.Rating"
                                         For="@(() => Input.Rating)"
                                         Label="Rating (0–5)"
                                         Min="0"
                                         Max="5"
                                         Variant="Variant.Outlined"
                                         Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="12" md="3">
                        <MudTextField T="string"
                                      @bind-Value="Input.DefaultCoverArtUrl"
                                      For="@(() => Input.DefaultCoverArtUrl)"
                                      Label="Default cover URL"
                                      Placeholder="https://..."
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField T="string"
                                      @bind-Value="Input.Notes"
                                      Label="Notes"
                                      Lines="3"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense" />
                    </MudItem>
                </MudGrid>
            </MudCardContent>
        </MudCard>
    </MudItem>

    <MudItem xs="12" md="4">
        <MudCard Elevation="0" Outlined="true" Class="h-100">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">Cover preview</MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent Class="d-flex justify-center align-center" Style="min-height: 240px;">
                @if (!string.IsNullOrWhiteSpace(Input.DefaultCoverArtUrl))
                {
                    <MudImage Src="@Input.DefaultCoverArtUrl"
                              Alt="Cover preview"
                              Style="max-height: 220px; max-width: 100%;"
                              loading="lazy"
                              decoding="async" />
                }
                else
                {
                    <MudText Typo="Typo.body2" Color="Color.Secondary">No cover set yet.</MudText>
                }
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>

@code {
    [Parameter, EditorRequired]
    public BookFormViewModel.BookFormInput Input { get; set; } = default!;
}
