@* MudBlazor genre picker. Two surfaces over a single SelectedGenreIds
   source of truth:
     1. Chips band — closeable chips per selected genre.
     2. MudAutocomplete input — type to search (substring, case-insensitive).
   All read from / write to the same parameter list. Picking a sub-genre
   auto-includes its parent so a "Dictionaries" selection implies
   "Reference" too.

   Optional LookupCandidates — informational badges shown below the
   autocomplete listing the raw upstream subjects from an ISBN lookup.
   Parent calls ApplyCandidatesAsync() to fuzzy-match those candidates
   against the preset catalogue and auto-select matches; the explicit
   call (rather than auto-apply on parameter change) keeps the user's
   manual edits sticky — removing a fuzzy match doesn't get undone by
   a downstream re-render. *@

@inject MudGenrePickerViewModel VM

<MudStack Spacing="2">

    @* Selected chips. *@
    @if (SelectedGenreIds.Count > 0)
    {
        <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">
            @foreach (var id in SelectedGenreIds)
            {
                var label = VM.ChipLabel(id);
                <MudChip T="string"
                         Size="Size.Small"
                         Variant="Variant.Filled"
                         Color="Color.Primary"
                         OnClose="@(() => OnRemoveAsync(id))">@label</MudChip>
            }
        </MudStack>
    }

    @* Typeahead input. *@
    <MudAutocomplete T="MudGenrePickerViewModel.GenreRow"
                     Value="null"
                     ValueChanged="OnAutocompletePick"
                     SearchFunc="SearchAsync"
                     ToStringFunc="@(g => g is null ? string.Empty : VM.DropdownLabel(g))"
                     Placeholder="Add a genre..."
                     Variant="Variant.Outlined"
                     Margin="Margin.Dense"
                     Clearable="true"
                     ResetValueOnEmptyText="true"
                     MinCharacters="0"
                     CoerceValue="false"
                     Adornment="Adornment.Start"
                     AdornmentIcon="@Icons.Material.Filled.Add" />

    @* Lookup candidate badges — informational. The matched ones are
       auto-selected via ApplyCandidatesAsync; the rest are shown as
       "the lookup also returned these subjects" hints so the user can
       decide whether to add them manually via the typeahead. *@
    @if (LookupCandidates.Count > 0)
    {
        <MudText Typo="Typo.caption" Color="Color.Secondary">
            Lookup returned (fuzzy-matched against the preset list):
        </MudText>
        <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">
            @foreach (var c in LookupCandidates)
            {
                <MudChip T="string"
                         Size="Size.Small"
                         Variant="Variant.Text"
                         Color="Color.Default">@c</MudChip>
            }
        </MudStack>
    }
</MudStack>

@code {
    [Parameter, EditorRequired] public List<int> SelectedGenreIds { get; set; } = [];
    [Parameter] public EventCallback<List<int>> SelectedGenreIdsChanged { get; set; }

    /// <summary>Informational badges from an ISBN lookup. Use
    /// <see cref="ApplyCandidatesAsync"/> to actually fuzzy-match
    /// and auto-select; the parameter alone just renders the chip
    /// row.</summary>
    [Parameter] public List<string> LookupCandidates { get; set; } = [];

    protected override async Task OnInitializedAsync()
    {
        await VM.InitializeAsync();
    }

    private Task<IEnumerable<MudGenrePickerViewModel.GenreRow>> SearchAsync(string query, CancellationToken ct)
        => Task.FromResult(VM.Search(query, SelectedGenreIds));

    private async Task OnAutocompletePick(MudGenrePickerViewModel.GenreRow? picked)
    {
        if (picked is null) return;
        var next = VM.AddGenre(picked.Id, SelectedGenreIds);
        await CommitAsync(next);
    }

    private async Task OnRemoveAsync(int id)
    {
        var next = VM.RemoveGenre(id, SelectedGenreIds);
        await CommitAsync(next);
    }

    /// <summary>Parent calls this after an ISBN lookup populates
    /// <see cref="LookupCandidates"/>: fuzzy-match each candidate
    /// against the preset list and add matches to the current
    /// selection. Idempotent on the AddGenre side (already-selected
    /// ids stay); manual removals after this call stick because the
    /// caller decides when to re-apply.</summary>
    public async Task ApplyCandidatesAsync(IReadOnlyList<string> candidates)
    {
        if (candidates is null || candidates.Count == 0) return;
        var next = VM.ApplyLookupCandidates(candidates, SelectedGenreIds);
        if (!next.SequenceEqual(SelectedGenreIds))
        {
            await CommitAsync(next);
        }
    }

    private async Task CommitAsync(List<int> next)
    {
        SelectedGenreIds = next;
        await SelectedGenreIdsChanged.InvokeAsync(next);
    }
}
