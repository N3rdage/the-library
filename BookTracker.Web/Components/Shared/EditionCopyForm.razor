@using BookTracker.Application
@using BookTracker.Application.Books
@using Microsoft.Extensions.Logging
@inject EditionFormViewModel EditionVM
@inject IDispatcher Dispatcher
@inject ILogger<EditionCopyForm> Logger

@* Edition + Copy fields for a new book being captured on /books/add.
   Publisher input is an autocomplete over existing Publisher rows
   (drops the previous Bootstrap datalist) — typing finds matches and
   the user can either pick an existing publisher or capture a new one
   by leaving the free text in place. *@

<MudCard Elevation="0" Outlined="true">
    <MudCardHeader>
        <CardHeaderContent>
            <MudText Typo="Typo.h6">@Title</MudText>
        </CardHeaderContent>
    </MudCardHeader>
    <MudCardContent>
        <MudGrid Spacing="3">
            <MudItem xs="12" md="3">
                <MudTextField T="string"
                              @bind-Value="EditionInput.Isbn"
                              For="@(() => EditionInput.Isbn)"
                              Label="ISBN"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="12" md="3">
                <MudSelect T="BookFormat"
                           @bind-Value="EditionInput.Format"
                           Label="Format"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense">
                    @foreach (var f in Enum.GetValues<BookFormat>())
                    {
                        <MudSelectItem T="BookFormat" Value="@f">@f.DisplayName()</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="3">
                <MudTextField T="string"
                              @bind-Value="EditionInput.DatePrinted"
                              Label="Date printed"
                              Placeholder="e.g. 1973, Oct 1973, or 12 Oct 1973"
                              HelperText="Year alone is fine if that's all you've got."
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="6" md="2">
                @* Revision number — 1st ed., 2nd ed., etc. Leave blank
                   for editions where it isn't surfaced on the cover. *@
                <MudNumericField T="int?"
                                 @bind-Value="EditionInput.EditionNumber"
                                 For="@(() => EditionInput.EditionNumber)"
                                 Label="Edition #"
                                 Placeholder="3"
                                 HelperText="1st, 2nd, 3rd..."
                                 Min="1"
                                 Max="99"
                                 Variant="Variant.Outlined"
                                 Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="6" md="3">
                <MudSelect T="BookCondition"
                           @bind-Value="CopyInput.Condition"
                           Label="Condition"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense">
                    @foreach (var c in Enum.GetValues<BookCondition>())
                    {
                        <MudSelectItem T="BookCondition" Value="@c">@CopyFormViewModel.FormatCondition(c)</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="6">
                @* Pick an existing publisher, or choose the "Add …" row to create
                   a new one. Creation is an explicit selection (no commit-on-blur
                   guessing) — the same gesture as the series field. *@
                <CreatableAutocomplete Value="@EditionInput.Publisher"
                                       ValueChanged="OnPublisherChosenAsync"
                                       SearchExisting="SearchPublishers"
                                       Label="Publisher"
                                       Placeholder="Penguin Books"
                                       HelperText="Pick an existing publisher, or choose the “Add …” row to create a new one." />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudTextField T="string"
                              @bind-Value="EditionInput.CoverUrl"
                              For="@(() => EditionInput.CoverUrl)"
                              Label="Edition cover URL (optional)"
                              Placeholder="Overrides the book's default cover"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense" />
            </MudItem>
        </MudGrid>
    </MudCardContent>
</MudCard>

@code {
    [Parameter, EditorRequired]
    public EditionFormViewModel.EditionFormInput EditionInput { get; set; } = default!;

    [Parameter, EditorRequired]
    public CopyFormViewModel.CopyFormInput CopyInput { get; set; } = default!;

    [Parameter]
    public string Title { get; set; } = "Edition & Copy";

    protected override async Task OnInitializedAsync()
    {
        await EditionVM.InitializeAsync();
    }

    // The only commit point for the publisher field: an explicit selection (an
    // existing pick, the "Add …" row, or the Clearable X → null). CoerceValue="false"
    // means typing alone never reaches here. Store the committed name (the save
    // resolves it via PublisherResolver — the net); a genuinely-new name is
    // eager-created now and cached, an existing pick is just stored (no round-trip).
    // The skip-existing / dispatch / swallow-fault logic is the shared
    // PublisherEagerCreate helper (one copy, one unit test, shared with the dialog).
    // internal so the bUnit test can invoke it directly.
    internal async Task OnPublisherChosenAsync(string? value)
    {
        EditionInput.Publisher = value?.Trim();
        var created = await PublisherEagerCreate.CreateIfNewAsync(
            EditionInput.Publisher, EditionVM.ExistingPublishers.Select(p => p.Name), Dispatcher, Logger);
        if (created is (int id, string name))
        {
            EditionVM.ExistingPublishers.Add(new EditionFormViewModel.PublisherOption(id, name));
        }
    }

    private Task<IEnumerable<string>> SearchPublishers(string? query, CancellationToken ct)
    {
        var q = (query ?? string.Empty).Trim();
        IEnumerable<string> matches = string.IsNullOrEmpty(q)
            ? EditionVM.ExistingPublishers.Select(p => p.Name)
            : EditionVM.ExistingPublishers
                .Where(p => p.Name.Contains(q, StringComparison.OrdinalIgnoreCase))
                .Select(p => p.Name);
        return Task.FromResult(matches);
    }
}
