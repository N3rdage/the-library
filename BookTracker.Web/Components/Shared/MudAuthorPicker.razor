@* Multi-author input with autocomplete + chips. Used on Add Book, the
   /edit page's Primary Work form, and the Work edit dialog (BookDetail
   modal). Flat list of names with find-or-create-on-save semantics.

   Two-way binding via `Authors` + `AuthorsChanged`:
       <MudAuthorPicker Authors="vm.Authors"
                        AuthorsChanged="list => vm.Authors = list" />

   Add semantics: pick a name from the dropdown OR type a new one and press
   Enter or comma to commit as a chip. `CoerceValue="false"` ensures
   intermediate keystrokes don't fire ValueChanged (which had shipped a
   chip-per-keystroke bug under CoerceValue="true").

   Enter and comma are handled entirely on the JS side
   (wwwroot/js/chip-picker-keys.js) — JS preventDefaults the key (so the
   surrounding form doesn't submit and the comma doesn't get inserted into
   the input) and then invokes the .NET-side OnCommitKey via
   DotNetObjectReference with the current input.value. Going through JS
   rather than Blazor's @onkeydown is necessary because preventDefault
   can't be made conditional on key value through pure managed code, and
   reading the autocomplete's Text from the .NET side at keydown time
   came back stale. *@

@implements IDisposable
@using BookTracker.Data
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<BookTrackerDbContext> DbFactory
@inject IJSRuntime JS

<MudPaper Outlined="true" Class="pa-2">
    @if (Authors.Count > 0)
    {
        <div class="d-flex flex-wrap gap-1 mb-2">
            @foreach (var name in Authors)
            {
                var captured = name;
                <MudChip T="string"
                         Text="@captured"
                         Variant="Variant.Filled"
                         Color="Color.Primary"
                         Size="Size.Small"
                         OnClose="@(() => RemoveAsync(captured))" />
            }
        </div>
    }
    @* Wrapping div gives us an ElementReference for the JS-side keydown
       suppressor to anchor on (MudPaper's @ref returns the component, not
       the DOM element). *@
    <div @ref="containerRef">
        <MudAutocomplete @ref="autocompleteRef"
                         T="string"
                         Value="@newAuthor"
                         ValueChanged="OnPickedAsync"
                         SearchFunc="SearchAsync"
                         Label="@Label"
                         Variant="Variant.Outlined"
                         Margin="Margin.Dense"
                         CoerceValue="false"
                         CoerceText="true"
                         ResetValueOnEmptyText="false"
                         MinCharacters="0"
                         ShowProgressIndicator="true"
                         HelperText="@HelperText" />
    </div>
</MudPaper>

@code {
    [Parameter, EditorRequired] public List<string> Authors { get; set; } = [];
    [Parameter] public EventCallback<List<string>> AuthorsChanged { get; set; }
    [Parameter] public string Label { get; set; } = "Author";
    [Parameter] public string HelperText { get; set; } = "Type to find existing or create new. Pick from the list, or press Enter or comma to add.";

    private string? newAuthor;
    private MudAutocomplete<string>? autocompleteRef;
    private ElementReference containerRef;
    private DotNetObjectReference<MudAuthorPicker>? selfRef;
    private bool keysSuppressed;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !keysSuppressed)
        {
            selfRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("chipPicker.suppressEnterAndComma", containerRef, selfRef);
            keysSuppressed = true;
        }
    }

    private async Task<IEnumerable<string>> SearchAsync(string query, CancellationToken ct)
    {
        // Lowercased client-side before the LINQ Where so EF InMemory (case-
        // sensitive) and SQL Server (case-insensitive default collation) agree
        // on substring matching. Mirrors WorkEditDialogViewModel.SearchAuthorsAsync.
        var q = (query ?? "").Trim().ToLower();
        await using var db = await DbFactory.CreateDbContextAsync();
        var matches = db.Authors.AsQueryable();
        if (!string.IsNullOrEmpty(q))
        {
            matches = matches.Where(a => a.Name.ToLower().Contains(q));
        }

        var existing = Authors.ToHashSet(StringComparer.OrdinalIgnoreCase);
        return await matches
            .OrderBy(a => a.Name)
            .Select(a => a.Name)
            .Where(n => !existing.Contains(n))
            .Take(20)
            .ToListAsync(ct);
    }

    private async Task OnPickedAsync(string? value)
    {
        // Fires when the user selects a name from the suggestion dropdown.
        // CoerceValue="false" prevents this from firing on intermediate
        // keystrokes (the original chip-per-keystroke bug).
        await TryAddAsync(value);
    }

    [JSInvokable]
    public async Task OnCommitKey(string text)
    {
        // Invoked by the JS-side keydown listener when the user presses Enter
        // or comma. `text` is the input.value at the exact moment of keydown
        // — reading the autocomplete's .NET-side Text property in OnKeyDown
        // had been returning stale or empty values, so the JS reads
        // input.value directly and passes it across.
        await TryAddAsync(text);
        StateHasChanged();
    }

    private async Task TryAddAsync(string? value)
    {
        if (string.IsNullOrWhiteSpace(value)) return;
        var trimmed = value.Trim().TrimEnd(',', ';', '&').Trim();
        if (string.IsNullOrEmpty(trimmed)) return;

        // Case-insensitive de-dup — typing an author already in the chip set
        // is a no-op rather than a duplicate.
        if (!Authors.Any(a => a.Equals(trimmed, StringComparison.OrdinalIgnoreCase)))
        {
            Authors.Add(trimmed);
            await AuthorsChanged.InvokeAsync(Authors);
        }
        newAuthor = null;

        // ClearAsync resets both the displayed text and the internal value
        // so the user can type the next author without manually clearing.
        if (autocompleteRef is not null)
        {
            await autocompleteRef.ClearAsync();
        }
    }

    private async Task RemoveAsync(string name)
    {
        Authors.RemoveAll(a => a.Equals(name, StringComparison.OrdinalIgnoreCase));
        await AuthorsChanged.InvokeAsync(Authors);
    }

    public void Dispose()
    {
        selfRef?.Dispose();
    }
}
