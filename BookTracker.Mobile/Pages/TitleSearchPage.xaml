<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BookTracker.Mobile.Pages.TitleSearchPage"
             Title="Find by title"
             BackgroundColor="#FAF6EC">

    <!-- "Find by title" — mirror of AuthorSearchPage. Debounced
         case-insensitive substring search (250ms, min 2 chars) over
         the offline catalog cache via SearchBooksByTitleAsync.

         No tap-through in v1 — the row itself answers the "do I own
         this?" intent. If a future use-case wants the per-book detail
         (editions, copies, format), this is the natural insertion
         point. -->

    <Grid RowDefinitions="Auto,Auto,*" Padding="20,16,20,0">

        <Entry x:Name="SearchEntry"
               Grid.Row="0"
               Placeholder="Search title…"
               PlaceholderColor="#6B5D4A"
               TextColor="#2C2416"
               BackgroundColor="#F2EADB"
               FontSize="16"
               Keyboard="Default"
               ReturnType="Search"
               TextChanged="OnSearchTextChanged" />

        <Label x:Name="HintLabel"
               Grid.Row="1"
               Text="Start typing — at least 2 characters. Searches any part of the title."
               FontSize="13"
               TextColor="#6B5D4A"
               LineBreakMode="WordWrap"
               Margin="0,12,0,0" />

        <ScrollView Grid.Row="2" Margin="0,12,0,0">
            <VerticalStackLayout x:Name="ResultsLayout"
                                 Spacing="8"
                                 Padding="0,0,0,20" />
        </ScrollView>
    </Grid>
</ContentPage>
