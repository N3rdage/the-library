<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BookTracker.Mobile.Pages.WishlistPage"
             Title="Wishlist"
             Style="{StaticResource Page}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Sync" Clicked="OnSyncClicked" />
    </ContentPage.ToolbarItems>

    <!-- Wishlist — books Drew is looking for. Backs the in-shop
         "what am I trying to buy?" use case that the Web /wishlist
         page captures. Read from the offline cache; refresh button
         pulls /api/wishlist-snapshot when network is available.

         "Bought" toggles a local-only flag that hides the row from
         this view; the row survives in the cache until the next
         catalog refresh, at which point either the server-side row
         is gone (Drew captured it via Bookcase) and the bought flag
         becomes a harmless orphan, or the row stays and the user
         can manually un-mark it (not yet — Phase 2 polish).

         Child page — system nav bar visible for back navigation. -->

    <Grid RowDefinitions="Auto,Auto,Auto,Auto,*" Padding="20,16,20,0">

        <Button x:Name="RefreshButton"
                Grid.Row="0"
                Text="↻  Refresh wishlist"
                Clicked="OnRefreshClicked"
                HeightRequest="44"
                BackgroundColor="{AppThemeBinding Light={StaticResource LeatherL}, Dark={StaticResource LeatherD}}"
                TextColor="{StaticResource OnLeather}"
                FontSize="14"
                CornerRadius="8"
                HorizontalOptions="Fill" />

        <ActivityIndicator x:Name="Busy"
                           Grid.Row="1"
                           IsRunning="False"
                           Color="{AppThemeBinding Light={StaticResource LeatherL}, Dark={StaticResource LeatherD}}"
                           HorizontalOptions="Center"
                           Margin="0,8,0,0" />

        <Label x:Name="StatusLabel"
               Grid.Row="2"
               Text="Loading…"
               FontSize="13"
               TextColor="{AppThemeBinding Light={StaticResource TextMutedL}, Dark={StaticResource TextMutedD}}"
               HorizontalTextAlignment="Center"
               LineBreakMode="WordWrap"
               Margin="0,8,0,0" />

        <!-- Sort segment (Priority / Author / Series) — shown only with items.
             Default Priority (with High/Medium/Low group headers). -->
        <Grid x:Name="SortSegment"
              Grid.Row="3"
              Padding="0,12,0,0"
              ColumnDefinitions="*,*,*"
              ColumnSpacing="8"
              IsVisible="False">
            <Button x:Name="SortPriorityButton" Text="Priority" Clicked="OnSortPriority" HeightRequest="40" CornerRadius="8" FontSize="13" />
            <Button x:Name="SortAuthorButton" Grid.Column="1" Text="Author" Clicked="OnSortAuthor" HeightRequest="40" CornerRadius="8" FontSize="13" />
            <Button x:Name="SortSeriesButton" Grid.Column="2" Text="Series" Clicked="OnSortSeries" HeightRequest="40" CornerRadius="8" FontSize="13" />
        </Grid>

        <ScrollView Grid.Row="4" Margin="0,12,0,0">
            <VerticalStackLayout x:Name="ItemsLayout"
                                 Spacing="8"
                                 Padding="0,0,0,20" />
        </ScrollView>
    </Grid>
</ContentPage>
