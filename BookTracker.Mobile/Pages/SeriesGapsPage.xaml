<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BookTracker.Mobile.Pages.SeriesGapsPage"
             Title="Series gaps"
             BackgroundColor="#FAF6EC">

    <!-- "Series gaps" — at-a-glance "what am I missing?" view for
         series where the user owns some but not all books. Mirror of
         the Web /shopping Card 2. Sources data from
         ICatalogCache.GetSeriesGapsAsync, which already filters out
         open-ended series and complete sets. Pure-render page; no
         interaction beyond the system back button. -->

    <ScrollView>
        <VerticalStackLayout x:Name="GapsLayout"
                             Padding="20,16,20,20"
                             Spacing="10" />
    </ScrollView>
</ContentPage>
