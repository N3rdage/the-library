<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:zxing="clr-namespace:ZXing.Net.Maui.Controls;assembly=ZXing.Net.MAUI.Controls"
             x:Class="BookTracker.Mobile.Pages.ScanPage"
             Title="Scan ISBN">

    <Grid RowDefinitions="*,Auto" Padding="0">

        <!-- Camera viewfinder. Constrained to a 4:3 aspect-ish region
             at the top; ZXing autodetects EAN-13/EAN-8 from the
             configured BarcodeReaderOptions below. -->
        <zxing:CameraBarcodeReaderView
            x:Name="Reader"
            Grid.Row="0"
            BarcodesDetected="OnBarcodesDetected"
            IsDetecting="True"
            IsTorchOn="False" />

        <!-- Letterbox + green scan-target overlay. Layered into the same
             Grid.Row="0" so it covers only the viewfinder, not the
             result panel below. InputTransparent so it can't intercept
             any camera-handler taps. Mirrors the Web /bookshop qrbox
             aspect (~3.5:1 — book barcode shape) via star sizing so it
             scales across screen sizes. -->
        <Grid Grid.Row="0"
              InputTransparent="True"
              RowDefinitions="1.5*,*,1.5*"
              ColumnDefinitions="*,6*,*">
            <!-- Four dark BoxViews forming the letterbox around the
                 scan window. Document order = z-order; these paint
                 before the green border. -->
            <BoxView Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Color="#B3000000" />
            <BoxView Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Color="#B3000000" />
            <BoxView Grid.Row="1" Grid.Column="0" Color="#B3000000" />
            <BoxView Grid.Row="1" Grid.Column="2" Color="#B3000000" />
            <!-- Scan target: transparent fill so the camera shows
                 through, green Stroke as the "centre the barcode here"
                 cue. -->
            <Border Grid.Row="1" Grid.Column="1"
                    BackgroundColor="Transparent"
                    Stroke="#4CAF50"
                    StrokeThickness="3">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="4" />
                </Border.StrokeShape>
            </Border>
        </Grid>

        <!-- Result panel — populated by code-behind after a detect or
             manual entry. Two states (in-cache / not-in-cache) are
             swapped by visibility. ManualEntry stays visible for users
             scanning a hard-to-read barcode. -->
        <ScrollView Grid.Row="1" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}">
            <VerticalStackLayout Padding="20" Spacing="12">

                <Label
                    x:Name="StatusLabel"
                    Text="Point the camera at a book's barcode."
                    HorizontalOptions="Center"
                    HorizontalTextAlignment="Center"
                    LineBreakMode="WordWrap" />

                <!-- Wishlist scan-flag — surfaces when the scanned ISBN
                     matches any wishlisted ISBN. Pre-positioned above
                     both FoundFrame and MissingFrame so the answer to
                     "am I looking for this?" is visible regardless of
                     whether the book is already owned. Brass accent
                     (the in-bookshop signal colour) — visually the
                     "BUY THIS" cue. -->
                <Border x:Name="WishlistFlag"
                        IsVisible="False"
                        Stroke="#A67B3A"
                        StrokeThickness="2"
                        BackgroundColor="#FAF6EC"
                        Padding="12,8">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>
                    <Label Text="⭐  On your wishlist"
                           FontSize="15"
                           FontAttributes="Bold"
                           TextColor="#6B2737"
                           HorizontalTextAlignment="Center" />
                </Border>

                <!-- In-cache result. Border (replaces obsolete Frame in
                     .NET 9+) — needs an explicit StrokeShape for the
                     corner-radius effect. Top row is two-column: cover
                     thumbnail on the left, primary text stack on the
                     right. Below sit two optional sections (Works for
                     compendiums, Editions for multi-edition books) —
                     populated and shown conditionally by code-behind.
                     Sections rendered as code-behind View children so
                     a variable row count works without XAML gymnastics. -->
                <Border
                    x:Name="FoundFrame"
                    IsVisible="False"
                    Stroke="{AppThemeBinding Light=#A3D9A5, Dark=#356735}"
                    BackgroundColor="{AppThemeBinding Light=#E8F5E9, Dark=#1B3320}"
                    Padding="12">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="12">
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                            <Grid Grid.Column="0"
                                  WidthRequest="80"
                                  HeightRequest="120"
                                  BackgroundColor="{AppThemeBinding Light=#E0DAC8, Dark=#2A2A2A}"
                                  VerticalOptions="Start">
                                <!-- Single child swaps between two states.
                                     Image is hidden until the local path
                                     lands; FoundCoverPlaceholder fills the
                                     grey square until then. -->
                                <Label x:Name="FoundCoverPlaceholder"
                                       Text="📖"
                                       FontSize="32"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"
                                       TextColor="{AppThemeBinding Light=#A67B3A, Dark=#6B5D4A}" />
                                <Image x:Name="FoundCover"
                                       IsVisible="False"
                                       Aspect="AspectFit" />
                            </Grid>
                            <VerticalStackLayout Grid.Column="1" Spacing="6">
                                <Label x:Name="FoundTitle" FontAttributes="Bold" FontSize="18" />
                                <Label x:Name="FoundAuthors" FontSize="14" TextColor="{AppThemeBinding Light=#555, Dark=#BBB}" />
                                <Label x:Name="FoundStatusRating" FontSize="13" />
                                <Label x:Name="FoundIsbn" FontSize="12" FontFamily="Courier New" TextColor="{AppThemeBinding Light=#555, Dark=#BBB}" />
                                <Button x:Name="OpenInAppButton" Text="Open in app →" Clicked="OnOpenInAppClicked" HorizontalOptions="Start" />
                            </VerticalStackLayout>
                        </Grid>

                        <!-- Works section — hidden by default; shown when
                             the Book has more than one Work (compendium).
                             Header label + rows populated in code-behind. -->
                        <VerticalStackLayout x:Name="WorksSection"
                                             IsVisible="False"
                                             Spacing="4">
                            <Label Text="Works in this book"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#3E2723, Dark=#A67B3A}" />
                            <VerticalStackLayout x:Name="WorksLayout" Spacing="4" />
                        </VerticalStackLayout>

                        <!-- Editions section — hidden by default; shown
                             when the Book has more than one Edition. -->
                        <VerticalStackLayout x:Name="EditionsSection"
                                             IsVisible="False"
                                             Spacing="4">
                            <Label Text="Editions you own"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#3E2723, Dark=#A67B3A}" />
                            <VerticalStackLayout x:Name="EditionsLayout" Spacing="6" />
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- Not-in-cache result -->
                <Border
                    x:Name="MissingFrame"
                    IsVisible="False"
                    Stroke="{AppThemeBinding Light=#DDD, Dark=#555}"
                    BackgroundColor="{AppThemeBinding Light=#FAFAFA, Dark=#252525}"
                    Padding="12">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Not in your library." FontAttributes="Bold" />
                        <Label x:Name="MissingIsbn" FontSize="12" FontFamily="Courier New" TextColor="{AppThemeBinding Light=#555, Dark=#BBB}" />
                        <Button x:Name="AddToLibraryButton" Text="Add in app →" Clicked="OnAddToLibraryClicked" HorizontalOptions="Start" />
                    </VerticalStackLayout>
                </Border>

                <!-- Manual ISBN entry — for damaged barcodes or hand
                     typing from a back cover. Numeric keyboard is the
                     default because the 99% case is typing 10-13
                     digits (the on-screen numeric keypad has big keys;
                     a default keyboard's number row is cramped). The
                     +X button alongside is the alternate path for the
                     ~1% case: ISBN-10 ending in the X check digit,
                     which the numeric keypad can't produce. The
                     cleanup in OnManualLookupClicked already permits
                     X / x so no validation change is needed. -->
                <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#EEE, Dark=#333}" />
                <Label Text="Or enter ISBN manually:" FontSize="13" />
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                    <Entry
                        x:Name="ManualEntry"
                        Grid.Column="0"
                        Keyboard="Numeric"
                        Placeholder="9780553287899"
                        ReturnType="Search"
                        Completed="OnManualLookupClicked" />
                    <Button
                        Grid.Column="1"
                        Text="+X"
                        Clicked="OnAppendXClicked"
                        WidthRequest="48"
                        BackgroundColor="#F2EADB"
                        TextColor="#2C2416"
                        BorderColor="#A67B3A"
                        BorderWidth="1"
                        FontSize="16"
                        CornerRadius="6" />
                    <Button
                        Grid.Column="2"
                        Text="Lookup"
                        Clicked="OnManualLookupClicked" />
                </Grid>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
